{
  "rules": [
    {
      "id": "@secretlint/secretlint-rule-preset-recommend"
    },
    {
      "id": "@secretlint/secretlint-rule-pattern",
      "options": {
        "patterns": [
          {
            "name": "PET_TRAINER_TOKEN credential",
            "pattern": "/PET_TRAINER_TOKEN=[A-Za-z0-9._-]{20,}/g"
          }
        ]
      }
    }
  ]
}
