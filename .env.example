# pet-trainer environment variables
# Copy this file to .env (local dev) or set values in Vercel/CI secrets (deploy).
# NEVER commit a populated .env file. The .gitignore enforces this.

# --- CLI auth (per SPEC.md §6.4 / ADR-003) ---
# Set automatically by `pet init` after device-code OAuth completes.
# The CLI shell rc export is what the HTTP hook reads at tool-call time.
PET_TRAINER_TOKEN=

# --- Supabase (per SPEC.md §5.1, §10.4) ---
# Public client config — safe for the browser bundle (RLS is the security layer).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# SERVER ONLY — never expose to Edge Runtime or client.
# Used by /api/v1/events Node function to insert into the events table (bypasses RLS).
SUPABASE_SERVICE_ROLE_KEY=

# --- Upstash Redis (per SPEC.md §5.2) ---
# Edge-compatible HTTP REST endpoint. Used for rate limit, leaderboard ZSET, session cache.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- GitHub OAuth (Supabase Auth provider — see SPEC.md §6.1, ADR-001) ---
# Create a GitHub OAuth App at https://github.com/settings/developers with
# callback URL http://127.0.0.1:54321/auth/v1/callback (local) or
# https://<your-project>.supabase.co/auth/v1/callback (prod).
# Read by supabase/config.toml's env() interpolation at supabase start time.
SUPABASE_AUTH_GITHUB_CLIENT_ID=
SUPABASE_AUTH_GITHUB_SECRET=
