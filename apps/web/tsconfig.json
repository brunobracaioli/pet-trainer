{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "jsx": "preserve",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "plugins": [
      {
        "name": "next"
      }
    ],
    "types": ["node"],
    "allowJs": true,
    "incremental": true,
    "isolatedModules": true
  },
  "include": ["app", "next-env.d.ts", "src", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
